DATABASE_PATH=./data/landlord.db
SESSION_SECRET=your-super-secret-key-change-in-production
NEXT_PUBLIC_DEFAULT_BG_URL=https://images.unsplash.com/photo-1545324418-cc1a3fa10c00

# 应用基础 URL（用于构建重定向地址，生产环境必须设置）
APP_URL=http://localhost:3000

# Discord OAuth 配置（可选）
# 在 https://discord.com/developers/applications 创建应用获取
# 如果不配置，Discord 登录功能将被禁用
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback

# SiliconFlow API 配置（用于AI生图）
# 在 https://cloud.siliconflow.cn/ 注册获取 API Key
SILICONFLOW_API_KEY=sk-lxyuvnsjzjjyscdydksumgivayqihstnscshsfxngfqggntf